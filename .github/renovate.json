{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": ["renovate"],
  "semanticCommits": "enabled",
  "packageRules": [
    {
      "description": "Versioning for qbittorrent (version-x.y.z-rN format)",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["lscr.io/linuxserver/qbittorrent"],
      "versioning": "regex:^version-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-r(?<build>\\d+)$"
    },
    {
      "description": "Group linuxserver image updates together",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/lscr\\.io\\/linuxserver\\/.*/"],
      "groupName": "linuxserver images"
    },
    {
      "description": "Auto-merge GitHub Actions minor/patch/digest as branch",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "branch",
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Semantic commits - major",
      "matchUpdateTypes": ["major"],
      "semanticCommitType": "feat",
      "commitMessagePrefix": "{{semanticCommitType}}({{semanticCommitScope}})!:",
      "commitMessageExtra": "( {{currentVersion}} → {{newVersion}} )"
    },
    {
      "description": "Semantic commits - minor",
      "matchUpdateTypes": ["minor"],
      "semanticCommitType": "feat",
      "commitMessageExtra": "( {{currentVersion}} → {{newVersion}} )"
    },
    {
      "description": "Semantic commits - patch",
      "matchUpdateTypes": ["patch"],
      "semanticCommitType": "chore",
      "commitMessageExtra": "( {{currentVersion}} → {{newVersion}} )"
    },
    {
      "description": "Semantic commits - digest",
      "matchUpdateTypes": ["digest"],
      "semanticCommitType": "chore",
      "commitMessageExtra": "( {{currentDigestShort}} → {{newDigestShort}} )"
    },
    {
      "description": "Semantic scope for containers",
      "matchDatasources": ["docker"],
      "semanticCommitScope": "container",
      "commitMessageTopic": "image {{depName}}"
    },
    {
      "description": "Semantic scope for GitHub Actions",
      "matchManagers": ["github-actions"],
      "semanticCommitType": "ci",
      "semanticCommitScope": "github-action",
      "commitMessageTopic": "action {{depName}}"
    },
    {
      "description": "Labels by update type",
      "matchUpdateTypes": ["major"],
      "labels": ["type/major"]
    },
    {
      "matchUpdateTypes": ["minor"],
      "labels": ["type/minor"]
    },
    {
      "matchUpdateTypes": ["patch"],
      "labels": ["type/patch"]
    },
    {
      "matchUpdateTypes": ["digest"],
      "labels": ["type/digest"]
    },
    {
      "matchDatasources": ["docker"],
      "addLabels": ["renovate/container"]
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["renovate/github-action"]
    },
    {
      "matchPackageNames": ["cloudflare/cloudflared"],
      "changelogUrl": "https://github.com/cloudflare/cloudflared/blob/master/RELEASE_NOTES"
    },
    {
      "matchPackageNames": ["kometateam/kometa"],
      "changelogUrl": "https://github.com/Kometa-Team/Kometa/releases"
    },
    {
      "matchPackageNames": ["lakker/pulsarr"],
      "changelogUrl": "https://github.com/jamcalli/Pulsarr/releases"
    },
    {
      "matchPackageNames": ["justarchi/archisteamfarm"],
      "changelogUrl": "https://github.com/JustArchiNET/ArchiSteamFarm/releases"
    },
    {
      "matchPackageNames": ["ghcr.io/cleanuparr/cleanuparr"],
      "changelogUrl": "https://github.com/cleanuparr/cleanuparr/releases"
    },
    {
      "matchPackageNames": ["ghcr.io/recyclarr/recyclarr"],
      "changelogUrl": "https://github.com/recyclarr/recyclarr/releases"
    },
    {
      "matchPackageNames": ["flaresolverr/flaresolverr"],
      "changelogUrl": "https://github.com/FlareSolverr/FlareSolverr/releases"
    },
    {
      "matchPackageNames": ["ghcr.io/home-assistant/home-assistant"],
      "changelogUrl": "https://github.com/home-assistant/core/releases"
    },
    {
      "matchPackageNames": ["henrygd/beszel-agent", "henrygd/beszel"],
      "changelogUrl": "https://github.com/henrygd/beszel/releases"
    },
    {
      "matchPackageNames": ["portainer/portainer-ce"],
      "changelogUrl": "https://github.com/portainer/portainer/releases"
    }
  ]
}

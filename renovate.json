{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>lachlan443/iac//.renovate/autoMerge.json5",
    "github>lachlan443/iac//.renovate/labels.json5",
    "github>lachlan443/iac//.renovate/semantic.json5",
    "github>lachlan443/iac//.renovate/versioning.json5",
    "github>lachlan443/iac//.renovate/changelogs.json5",
    "github>lachlan443/iac//.renovate/groups.json5"
  ],
  "labels": ["renovate"],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "semanticCommits": "enabled",
  "customManagers": [
    {
      "description": "ASF - use GitHub releases to respect pre-release flag",
      "customType": "regex",
      "managerFilePatterns": [
        "/docker/.+/compose\\.yaml$/"
      ],
      "matchStrings": ["justarchi/archisteamfarm:(?<currentValue>[^\\s]+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "JustArchiNET/ArchiSteamFarm"
    }
  ],
  "packageRules": [
    {
      "description": "ASF - disable built-in docker manager so custom github-releases manager takes over",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["justarchi/archisteamfarm"],
      "enabled": false
    },
    {
      "description": "Renovate uses :latest tag, no need to track versions",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["renovate/renovate"],
      "enabled": false
    },
    {
      "description": "ASF - use 4-part versioning and ignore pre-releases",
      "matchDatasources": ["github-releases"],
      "matchPackageNames": ["JustArchiNET/ArchiSteamFarm"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)$",
      "ignoreUnstable": true
    }
  ]
}

{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Group beszel hub and agent together (shared versioning)",
      matchDatasources: ["docker"],
      matchPackageNames: ["henrygd/beszel", "henrygd/beszel-agent"],
      groupName: "beszel",
    },
  ],
}
